# ============================================================
# Backend — copy this block to backend/.env
# ============================================================

PORT=5000
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/mobility_rental
JWT_SECRET=replace_with_a_long_random_string
FRONTEND_URL=http://localhost:5173

# Stripe (use test keys for development)
STRIPE_SECRET_KEY=sk_test_xxx

# OpenAI DALL-E image generation (optional — falls back to placeholder images)
OPENAI_API_KEY=sk-proj-xxx
OPENAI_IMAGE_MODEL=dall-e-3

# Google Maps / Places API
GOOGLE_MAPS_API_KEY=AIza...

# Email notifications via Gmail (optional)
EMAIL_USER=your@gmail.com
EMAIL_PASS=your_gmail_app_password

# SMS notifications via Twilio (optional)
TWILIO_ACCOUNT_SID=ACxxx
TWILIO_AUTH_TOKEN=xxx
TWILIO_PHONE_NUMBER=+10000000000

# Admin account seeded on first boot
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_me_in_production

# ============================================================
# Frontend — copy this block to frontend/.env
# ============================================================

VITE_API_URL=http://localhost:5000
VITE_GOOGLE_MAPS_API_KEY=AIza...
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
